<div class="text-center mt-5">
    <h1 class="display-4 fw-bold mb-3">🎵 Record Studio</h1>
    <p class="lead mb-4">
        Бронируй студии быстро и удобно
    </p>

    <div class="d-flex justify-content-center gap-3 mb-5">
        <a asp-controller="Bookings" asp-action="Index" class="btn btn-primary btn-lg px-4">
            📅 Bookings
        </a>
        <a asp-controller="Studios" asp-action="Index" class="btn btn-outline-light btn-lg px-4">
            🎧 Studios
        </a>
    </div>
</div>

<div class="row text-center">
    <div class="col-md-4">
        <div class="card bg-dark text-white shadow-lg border-0 h-100">
            <div class="card-body">
                <h5 class="card-title">🎙️ Студии</h5>
                <p class="card-text">Просматривай доступные студии и цены</p>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card bg-dark text-white shadow-lg border-0 h-100">
            <div class="card-body">
                <h5 class="card-title">⏰ Бронирование</h5>
                <p class="card-text">Выбирай удобное время</p>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card bg-dark text-white shadow-lg border-0 h-100">
            <div class="card-body">
                <h5 class="card-title">💸 Оплата</h5>
                <p class="card-text">Автоматический расчет стоимости</p>
            </div>
        </div>
    </div>
</div>